# ============================================================================
# AI Gateway Pro - Backend Environment Configuration Template
# Copy this file to `.env` and fill in real values.
# ============================================================================

# ---- General ----
APP_NAME=AI Gateway Pro
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# ---- Host Configuration ----
HOST=127.0.0.1
PORT=8080
WORKERS=1
RELOAD=false

# ---- CORS ----
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ---- Database (MySQL) ----
DATABASE_URL=mysql+pymysql://root:@localhost:3306/aigateway?charset=utf8mb4
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false
DATABASE_TEST_URL=mysql+pymysql://root:@localhost:3306/aigateway_test?charset=utf8mb4

# ---- Security ----
SECRET_KEY=CHANGE-ME-generate-with-scripts-generate-master-key
MASTER_PASSWORD_SALT=CHANGE-ME-random-salt-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ---- API ----
API_PREFIX=/api
API_V1_PREFIX=/api/v1
GATEWAY_PREFIX=/v1
PAGE_SIZE_DEFAULT=20
PAGE_SIZE_MAX=200

# ---- Logging ----
LOG_DIR=./logs
LOG_ROTATION=20 MB
LOG_RETENTION=14
LOG_FORMAT=json

# ---- Scheduler ----
SCHEDULER_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=300
STATISTICS_AGGREGATION_INTERVAL_SECONDS=600
LOG_CLEANUP_INTERVAL_SECONDS=3600
BACKUP_INTERVAL_SECONDS=86400
NOTIFICATION_CLEANUP_INTERVAL_SECONDS=7200

# ---- Providers ----
PLUGIN_DIRECTORY=./app/services/provider_plugins
PROVIDER_TIMEOUT_SECONDS=120
PROVIDER_MAX_RETRIES=3
PROVIDER_RETRY_BACKOFF_SECONDS=2
PROVIDER_COOLDOWN_SECONDS=60

# ---- Notifications ----
NOTIFY_DESKTOP_ENABLED=true
NOTIFY_EMAIL_ENABLED=false
NOTIFY_SLACK_ENABLED=false
NOTIFY_DISCORD_ENABLED=false
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_WEBHOOK_ENABLED=false
NOTIFY_EMAIL_SMTP=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_SLACK_WEBHOOK=
NOTIFY_DISCORD_WEBHOOK=
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_WEBHOOK_URL=

# ---- Backup ----
BACKUP_DIRECTORY=./backups
BACKUP_KEEP_COUNT=7
BACKUP_COMPRESSION=true

# ---- Tray / Auto-start ----
TRAY_ENABLED=true
AUTO_START_WITH_WINDOWS=false